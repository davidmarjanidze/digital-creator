# xAI Grok Imagine (video)
XAI_API_KEY=__PUT_YOUR_KEY_HERE__
XAI_BASE_URL=https://api.x.ai
XAI_VIDEO_MODEL=grok-imagine-video
XAI_VIDEO_DURATION_SECONDS=10
XAI_VIDEO_ASPECT_RATIO=2:3
XAI_VIDEO_RESOLUTION=720p
XAI_VIDEO_POLL_INTERVAL_MS=5000
XAI_VIDEO_POLL_TIMEOUT_MS=900000

# Google Gemini (text for prompts + captions)
GEMINI_API_KEY=__PUT_YOUR_KEY_HERE__
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# Instagram Graph API (Reels upload)
# Per-account credentials
# daily-relaxation-rhythm uses INSTAGRAM_DAILY_*
INSTAGRAM_DAILY_ACCESS_TOKEN=__PUT_YOUR_TOKEN_HERE__
INSTAGRAM_DAILY_IG_USER_ID=__PUT_IG_USER_ID_HERE__

# deep-relax-flow uses INSTAGRAM_DEEP_*
INSTAGRAM_DEEP_ACCESS_TOKEN=__PUT_YOUR_TOKEN_HERE__
INSTAGRAM_DEEP_IG_USER_ID=__PUT_IG_USER_ID_HERE__

# the-revived-canvas uses INSTAGRAM_CANVAS_*
INSTAGRAM_CANVAS_ACCESS_TOKEN=__PUT_YOUR_TOKEN_HERE__
INSTAGRAM_CANVAS_IG_USER_ID=__PUT_IG_USER_ID_HERE__

# Shared Graph settings
INSTAGRAM_GRAPH_BASE_URL=https://graph.facebook.com
INSTAGRAM_API_VERSION=v25.0
INSTAGRAM_UPLOAD_POLL_INTERVAL_MS=60000
INSTAGRAM_UPLOAD_POLL_MAX_ATTEMPTS=10

# Optional
BATCH_SIZE=20